#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BASE_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# shellcheck source=scripts/helpers/service_manager.sh
. "$BASE_DIR/scripts/helpers/service_manager.sh"

usage() {
  echo "Usage: $0 --new-name NAME [--old-name NAME] [--base-dir PATH] [--dry-run] [--start]" >&2
  exit 1
}

validate_service_name() {
  local service_name="$1"

  if [ -z "$service_name" ]; then
    echo "Service name cannot be empty." >&2
    exit 1
  fi

  if printf '%s' "$service_name" | grep -Eq '^-'; then
    echo "Invalid service name: $service_name" >&2
    echo "Service names must not begin with a dash." >&2
    exit 1
  fi

  if ! printf '%s' "$service_name" | grep -Eq '^[A-Za-z0-9_.-]+$'; then
    echo "Invalid service name: $service_name" >&2
    echo "Service names may only contain letters, numbers, underscores, dots, and hyphens." >&2
    exit 1
  fi
}

OLD_SERVICE=""
NEW_SERVICE=""
LOCK_BASE_DIR="$BASE_DIR"
DRY_RUN=false
START_AFTER_RENAME=false

while [ $# -gt 0 ]; do
  case "$1" in
    --old-name)
      [ $# -lt 2 ] && usage
      OLD_SERVICE="$2"
      shift 2
      ;;
    --new-name)
      [ $# -lt 2 ] && usage
      NEW_SERVICE="$2"
      shift 2
      ;;
    --base-dir)
      [ $# -lt 2 ] && usage
      LOCK_BASE_DIR="$2"
      shift 2
      ;;
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    --start)
      START_AFTER_RENAME=true
      shift
      ;;
    *)
      usage
      ;;
  esac
done

[ -z "$NEW_SERVICE" ] && usage
validate_service_name "$NEW_SERVICE"

LOCK_DIR="$LOCK_BASE_DIR/.locks"
SYSTEMD_UNITS_LOCK="$LOCK_DIR/systemd_services.lck"
SERVICE_LOCK="$LOCK_DIR/service.lck"
SYSTEMD_DIR="${SYSTEMD_DIR:-/etc/systemd/system}"

systemd_unit_known() {
  local unit_name="$1"

  _arthexis_systemd_unit_present "$unit_name" || [ -f "$SYSTEMD_DIR/$unit_name" ]
}

if [ -z "$OLD_SERVICE" ] && [ -f "$SERVICE_LOCK" ]; then
  OLD_SERVICE="$(tr -d '\r\n' < "$SERVICE_LOCK")"
fi

[ -z "$OLD_SERVICE" ] && {
  echo "Unable to determine current service name. Pass --old-name explicitly or create .locks/service.lck first." >&2
  exit 1
}

validate_service_name "$OLD_SERVICE"

if [ "$OLD_SERVICE" = "$NEW_SERVICE" ]; then
  echo "Service is already named '$NEW_SERVICE'; nothing to do."
  exit 0
fi

SERVICE_MODE="$(arthexis_detect_service_mode "$LOCK_DIR")"
ENABLE_CELERY=false
ENABLE_LCD=false
ENABLE_RFID=false
ENABLE_CAMERA=false

if [ "$SERVICE_MODE" != "$ARTHEXIS_SERVICE_MODE_SYSTEMD" ] && systemd_unit_known "${OLD_SERVICE}.service"; then
  SERVICE_MODE="$ARTHEXIS_SERVICE_MODE_SYSTEMD"
fi

if [ -f "$LOCK_DIR/celery.lck" ]; then
  ENABLE_CELERY=true
fi
if [ "$ENABLE_CELERY" = false ] && {
  systemd_unit_known "celery-${OLD_SERVICE}.service" || systemd_unit_known "celery-beat-${OLD_SERVICE}.service";
}; then
  ENABLE_CELERY=true
fi
if arthexis_lcd_feature_enabled "$LOCK_DIR"; then
  ENABLE_LCD=true
fi
if [ "$ENABLE_LCD" = false ] && [ ! -f "$LOCK_DIR/$ARTHEXIS_LCD_LOCK" ] && systemd_unit_known "lcd-${OLD_SERVICE}.service"; then
  ENABLE_LCD=true
fi
if [ -f "$LOCK_DIR/$ARTHEXIS_RFID_SERVICE_LOCK" ]; then
  ENABLE_RFID=true
fi
if [ "$ENABLE_RFID" = false ] && systemd_unit_known "rfid-${OLD_SERVICE}.service"; then
  ENABLE_RFID=true
fi
if [ -f "$LOCK_DIR/$ARTHEXIS_CAMERA_SERVICE_LOCK" ]; then
  ENABLE_CAMERA=true
fi
if [ "$ENABLE_CAMERA" = false ] && systemd_unit_known "camera-${OLD_SERVICE}.service"; then
  ENABLE_CAMERA=true
fi

if [ "$DRY_RUN" = true ]; then
  echo "Dry run only."
  echo "Base dir: $LOCK_BASE_DIR"
  echo "Rename: $OLD_SERVICE -> $NEW_SERVICE"
  echo "Mode: $SERVICE_MODE"
  echo "Companions: celery=$ENABLE_CELERY lcd=$ENABLE_LCD rfid=$ENABLE_RFID camera=$ENABLE_CAMERA"
  exit 0
fi

mkdir -p "$LOCK_DIR"

echo "Stopping old unit stack for '$OLD_SERVICE'..."
arthexis_stop_service_unit_stack "$OLD_SERVICE" "$ENABLE_CELERY" "$ENABLE_LCD" "$ENABLE_RFID" "$ENABLE_CAMERA"

echo "Removing old unit stack for '$OLD_SERVICE'..."
arthexis_remove_service_unit_stack "$LOCK_DIR" "$OLD_SERVICE" "$ENABLE_CELERY" "$ENABLE_LCD" "$ENABLE_RFID" "$ENABLE_CAMERA"
arthexis_remove_systemd_unit_if_present "$LOCK_DIR" "${OLD_SERVICE}-upgrade-guard.service"
arthexis_remove_systemd_unit_if_present "$LOCK_DIR" "${OLD_SERVICE}-upgrade-guard.timer"

if [ "$SERVICE_MODE" = "$ARTHEXIS_SERVICE_MODE_SYSTEMD" ]; then
  echo "Installing new unit stack for '$NEW_SERVICE'..."
  EXEC_CMD="$LOCK_BASE_DIR/scripts/service-start.sh"
  arthexis_install_service_stack "$LOCK_BASE_DIR" "$LOCK_DIR" "$NEW_SERVICE" "$ENABLE_CELERY" "$EXEC_CMD" "$SERVICE_MODE"

  if [ "$ENABLE_LCD" = true ]; then
    arthexis_install_lcd_service_unit "$LOCK_BASE_DIR" "$LOCK_DIR" "$NEW_SERVICE"
  fi
  if [ "$ENABLE_RFID" = true ]; then
    arthexis_install_rfid_service_unit "$LOCK_BASE_DIR" "$LOCK_DIR" "$NEW_SERVICE"
  fi
  if [ "$ENABLE_CAMERA" = true ]; then
    arthexis_install_camera_service_unit "$LOCK_BASE_DIR" "$LOCK_DIR" "$NEW_SERVICE"
  fi

  if [ "$START_AFTER_RENAME" = true ]; then
    echo "Starting new service units for '$NEW_SERVICE'..."
    arthexis_start_systemd_unit_if_present "${NEW_SERVICE}.service"
    if [ "$ENABLE_CELERY" = true ]; then
      arthexis_start_systemd_unit_if_present "celery-${NEW_SERVICE}.service"
      arthexis_start_systemd_unit_if_present "celery-beat-${NEW_SERVICE}.service"
    fi
    if [ "$ENABLE_LCD" = true ]; then
      arthexis_start_systemd_unit_if_present "lcd-${NEW_SERVICE}.service"
    fi
    if [ "$ENABLE_RFID" = true ]; then
      arthexis_start_systemd_unit_if_present "rfid-${NEW_SERVICE}.service"
    fi
    if [ "$ENABLE_CAMERA" = true ]; then
      arthexis_start_systemd_unit_if_present "camera-${NEW_SERVICE}.service"
    fi
  fi
else
  echo "Service mode is '$SERVICE_MODE'; skipping systemd unit install."
fi

echo "$NEW_SERVICE" > "$SERVICE_LOCK"

echo "Renamed service '$OLD_SERVICE' -> '$NEW_SERVICE'."
